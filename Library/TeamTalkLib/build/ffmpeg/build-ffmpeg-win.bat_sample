SET PATH=@NASM_EXE_DIRECTORY_NATIVE@;%PATH%
SET MSYS2_PATH_TYPE=inherit
SET CHERE_INVOKING=1
@BASH_EXE_PATH@ --login -c "export PKG_CONFIG=/usr/bin/pkgconf && export PKG_CONFIG_PATH=@OPENSSL_PKG_CONFIG_DIR@:@ZLIB_PKG_CONFIG_DIR@ && ./configure --prefix=@FFMPEG_INSTALL_DIR@ --toolchain=msvc --arch=@FFMPEG_ARCH@ --target-os=@FFMPEG_TARGET_OS@ --disable-doc --disable-programs --disable-autodetect --disable-debug --enable-zlib --enable-openssl --pkg-config-flags=--static && make @TOOLCHAIN_BUILD_MAKEJOBS@ && make install"
